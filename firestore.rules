rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isValidScore(data) {
      return data.userId == request.auth.uid 
          && data.score is number 
          && data.score >= 0
          && data.timestamp == request.time;
    }

    function isValidUser(data) {
      return data.userId == request.auth.uid
          && (data.displayName is string || !('displayName' in data))
          && (data.highScore is number || !('highScore' in data));
    }

    // Leaderboard rules
    match /leaderboard/{scoreId} {
      allow list: if true; // Public leaderboard
      allow get: if true;
      allow create: if isSignedIn() && isValidScore(request.resource.data);
      allow update, delete: if false; // Scores are immutable
    }

    // User profile rules
    match /users/{userId} {
      allow get: if true;
      allow list: if false;
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) 
                    && request.resource.data.userId == resource.data.userId;
      allow delete: if false;
    }
  }
}
